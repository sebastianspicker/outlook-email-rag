# ── Core storage ──────────────────────────────────────────────
# Live operator default: keep the active runtime under private/runtime/current/.
# For tracked sanitized demos only, switch these explicitly back to data/... paths.
CHROMADB_PATH=private/runtime/current/chromadb
SQLITE_PATH=private/runtime/current/email_metadata.db
COLLECTION_NAME=emails

# ── Embedding model ──────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
DEVICE=auto                   # auto → MPS (Apple Silicon) → CUDA → CPU
RUNTIME_PROFILE=quality       # balanced | quality | low-memory | offline-test
EMBEDDING_LOAD_MODE=auto      # auto = cache first then download, local_only = refuse downloads, download = allow immediately

# ── BGE-M3 multi-vector features ────────────────────────────
#
# BGE-M3 supports three retrieval modes in a single forward pass:
#   1. Dense (1024-d cosine) — always on
#   2. Sparse (learned lexical weights) — requires SPARSE_ENABLED=true
#   3. ColBERT (token-level MaxSim) — requires COLBERT_RERANK_ENABLED=true
#
# RE-INGESTION REQUIREMENTS:
#   - Sparse vectors are computed at ingest time and stored in SQLite.
#     Enabling SPARSE_ENABLED after initial ingestion requires re-running
#     `email-rag-ingest` to populate the sparse index.
#   - ColBERT vectors are computed on-the-fly at query time from document
#     text already in ChromaDB. No re-ingestion needed.
#   - Dense vectors are always computed during ingestion. No action needed.
#   - HYBRID_ENABLED, RERANK_ENABLED: pure query-time features, no re-ingestion.
#
# `RUNTIME_PROFILE=quality` already enables sparse retrieval, ColBERT reranking,
# hybrid search, and cross-encoder reranking. Uncomment overrides only when you
# intentionally want to deviate from the profile defaults.
# SPARSE_ENABLED=true
# COLBERT_RERANK_ENABLED=true

# ── Reranking ────────────────────────────────────────────────
# Cross-encoder reranking (fallback when ColBERT is unavailable).
# No re-ingestion required — runs at query time.
# RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ── Hybrid search ────────────────────────────────────────────
# Fuses semantic (dense) + keyword (sparse/BM25) results via Reciprocal Rank Fusion.
# No re-ingestion required — uses existing dense + sparse indices.
# HYBRID_ENABLED=true

# ── Apple Silicon tuning ─────────────────────────────────────
EMBEDDING_BATCH_SIZE=0        # auto-detect (MPS: 32 for 16 GB, 48 for 36 GB+)
MPS_FLOAT16=false             # float32 default — fp16 causes silent numerical drift on MPS
MPS_CACHE_CLEAR_ENABLED=0     # torch.mps.empty_cache() is opt-in; current Torch/MPS stacks can crash
MPS_CACHE_CLEAR_INTERVAL=1    # only used when MPS_CACHE_CLEAR_ENABLED=1

# ── Ingestion performance ────────────────────────────────────
INGEST_BATCH_COOLDOWN=1               # seconds between batches (prevents M4 Air thermal throttling)
INGEST_WAL_CHECKPOINT_INTERVAL=10     # checkpoint SQLite WAL every N batches

# ── MCP response profile ────────────────────────────────────
# Profiles: tight, balanced (default), generous.
# "auto" = balanced. Set to match the calling MCP client.
# Per-variable env overrides always take precedence over profiles.
MCP_MODEL_PROFILE=auto

# MCP response size limits (defaults shown are for the balanced/auto profile):
# MCP_MAX_BODY_CHARS=500            # Max chars per email body in search results
# MCP_MAX_RESPONSE_TOKENS=8000      # Max total tokens for search responses
# MCP_MAX_FULL_BODY_CHARS=10000     # Soft limit for email_deep_context body
# MCP_MAX_JSON_RESPONSE_CHARS=32000 # Safety net for all JSON tool responses
# MCP_MAX_TRIAGE_RESULTS=50         # Max results per email_triage call
# MCP_MAX_SEARCH_RESULTS=30         # Max results per email_search_structured call

# ── Search defaults ──────────────────────────────────────────
TOP_K=10
LOG_LEVEL=INFO
ANALYTICS_TIMEZONE=          # optional IANA zone for analytics display bucketing, e.g. Europe/Berlin

# ── Progressive scan ─────────────────────────────────────────
# SCAN_SESSION_TTL=3600             # Session auto-expire in seconds (default: 1 hour)

# ── OLM parsing limits ───────────────────────────────────────
# OLM_MAX_XML_BYTES=50000000        # Max bytes per XML file (default: 50 MB)
# OLM_MAX_XML_FILES=500000          # Max XML files to parse (default: 500,000)

# ── Auto-download ────────────────────────────────────────────
SPACY_AUTO_DOWNLOAD=1               # downloads en_core_web_sm + de_core_news_sm (~30 MB each)
IMAGE_EMBED_AUTO_DOWNLOAD=1         # downloads Visualized_m3.pth (~2.3 GB) for image search
# IMAGE_EMBED_ALLOW_LOW_MEMORY=1    # force-enable image embedding on <=16 GB machines (not recommended)
