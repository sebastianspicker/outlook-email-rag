# Optional overrides (all have sensible defaults)
CHROMADB_PATH=data/chromadb
SQLITE_PATH=data/email_metadata.db
EMBEDDING_MODEL=BAAI/bge-m3
COLLECTION_NAME=emails
TOP_K=10
LOG_LEVEL=INFO
RERANK_ENABLED=false
RERANK_MODEL=BAAI/bge-reranker-v2-m3
HYBRID_ENABLED=false
DEVICE=auto

# BGE-M3 multi-vector features (all optional, default: disabled)
SPARSE_ENABLED=false
COLBERT_RERANK_ENABLED=false  # ColBERT reranking is tried first; cross-encoder is used as fallback
EMBEDDING_BATCH_SIZE=0  # 0 = auto-detect (MPS: 32, CUDA: 64, CPU: 16)
MPS_FLOAT16=false  # opt-in: use fp16 on MPS for ~2x throughput (requires PYTORCH_ENABLE_MPS_FALLBACK=1)
MPS_CACHE_CLEAR_INTERVAL=1  # clear MPS GPU cache every N encode calls (prevents memory buildup)

# Ingestion performance tuning (sustained workloads on Apple Silicon)
INGEST_BATCH_COOLDOWN=0               # seconds to sleep between batches (0=off, 2=recommended for thermal throttling)
INGEST_WAL_CHECKPOINT_INTERVAL=10     # checkpoint SQLite WAL every N batches (0=off, keeps WAL file bounded)

# MCP model profile — selects budget defaults for the calling model's context size.
# Profiles: haiku (tight), sonnet (balanced, default), opus (generous).
# "auto" = sonnet. Per-variable env overrides always take precedence.
# MCP_MODEL_PROFILE=auto

# MCP response size limits (prevent context window exhaustion)
# Defaults shown are for the sonnet/auto profile.
# MCP_MAX_BODY_CHARS=500            # Max chars per email body in search results (0=unlimited)
# MCP_MAX_RESPONSE_TOKENS=8000      # Max total tokens for search responses (0=unlimited)
# MCP_MAX_FULL_BODY_CHARS=10000     # Soft limit for email_get_full (0=unlimited)
# MCP_MAX_JSON_RESPONSE_CHARS=32000 # Safety net for all JSON tool responses (~8K tokens; 0=unlimited)
# MCP_MAX_TRIAGE_RESULTS=50         # Max results per email_triage call
# MCP_MAX_SEARCH_RESULTS=30         # Max results per email_search_structured call

# Progressive scan session TTL in seconds (default: 3600 = 1 hour). Sessions auto-expire.
# SCAN_SESSION_TTL=3600

# Auto-download models on first ingestion (set to 0 to disable)
SPACY_AUTO_DOWNLOAD=1         # downloads en_core_web_sm + de_core_news_sm (~30 MB each)
IMAGE_EMBED_AUTO_DOWNLOAD=1   # downloads Visualized_m3.pth (~2.3 GB) for image search
